---
import Layout from '../layouts/Layout.astro';
import EpisodeList from '../components/EpisodeList.astro';
import InfoCard from '../components/InfoCard.astro';
import { getRequestedFeed, resolveFeedSource } from '../lib/feed-source';
import { getAllEpisodes, getShowInfo } from '../lib/rss';
import starpodConfig from '../../starpod.config';

const searchParams = Astro.url.searchParams;
const feedSource = resolveFeedSource(getRequestedFeed(searchParams));
const feedUrl = feedSource.resolvedUrl;
const showPanel = searchParams.get('show') === 'true';

// Run both fetches concurrently; show info may fail gracefully
const [episodes, show] = await Promise.allSettled([
  getAllEpisodes(feedUrl),
  getShowInfo(feedUrl)
]);

const episodesArray = episodes.status === 'fulfilled' ? episodes.value : [];
const showInfo = show.status === 'fulfilled' ? show.value : undefined;

// EpisodeList needs a Show object for image fallback
const showData = showInfo ?? { title: starpodConfig.blurb ?? 'Podcast', description: '', image: '', link: '' };

const pageTitle = showInfo?.title ?? starpodConfig.blurb ?? 'Starpod';

// Only pass a feed param forward when it resolves to a non-default source.
const feedParam = feedSource.queryValue;
---

<Layout feedQueryValue={feedParam} feedUrl={feedUrl} show={showData} title={pageTitle}>
  <div class="container mx-auto px-4 py-8 lg:px-8">
    <div class="flex flex-col gap-8 lg:flex-row">
      {showPanel && (
        <aside class="w-full lg:w-80 lg:shrink-0">
          <InfoCard hideHosts={!feedSource.isDefault} info={showInfo} />
        </aside>
      )}
      <div class={`w-full min-w-0`}>
        <EpisodeList episodes={episodesArray} show={showData} feed={feedParam} />
      </div>
    </div>
  </div>
</Layout>
