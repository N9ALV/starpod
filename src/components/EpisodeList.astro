---
import { format } from 'date-fns';
import type { Episode } from '../lib/rss';

interface Props {
  episodes: Episode[];
  feed?: string;
}

const { episodes } = Astro.props;
---

{episodes.length === 0 ? (
  <p class="text-center text-muted-foreground py-16">No episodes found.</p>
) : (
  <ul class="flex flex-col gap-4">
    {episodes.map((episode) => (
      <li class="flex gap-4 rounded-lg bg-card shadow-sm p-4 hover:shadow-md transition-shadow">
        {episode.episodeImage && (
          <img
            src={episode.episodeImage}
            alt={episode.title}
            class="h-16 w-16 shrink-0 rounded object-cover"
            loading="lazy"
            onerror="this.style.display='none'"
          />
        )}
        <div class="flex flex-col gap-1 min-w-0">
          {episode.episodeNumber && (
            <span class="text-xs font-medium text-primary">Ep {episode.episodeNumber}</span>
          )}
          <h3 class="font-semibold text-card-foreground truncate">{episode.title}</h3>
          <p class="text-sm text-muted-foreground line-clamp-2">{episode.description}</p>
          {episode.published > 0 && (
            <p class="text-xs text-muted-foreground mt-1">
              {format(new Date(episode.published), 'MMM d, yyyy')}
            </p>
          )}
          {episode.audio?.src && (
            <audio
              controls
              preload="none"
              class="mt-2 w-full"
              src={episode.audio.src}
            />
          )}
        </div>
      </li>
    ))}
  </ul>
)}