---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import { Schema } from 'astro-seo-schema';

import SpeedInsights from '@vercel/speed-insights/astro';

import Breadcrumbs from '../components/Breadcrumbs.astro';
import Dots from '../components/Dots.astro';
import Hosts from '../components/Hosts.astro';
import InfoCard from '../components/InfoCard.astro';
import Platforms from '../components/Platforms.astro';
import Player from '../components/Player';
import SearchButton from '../components/SearchButton';
import SearchDialog from '../components/SearchDialog';
import ShowArtwork from '../components/ShowArtwork.astro';

import { getEmbedGateConfig } from '../lib/embed-gate';
import { getShowInfo } from '../lib/rss';
import type { Show } from '../lib/rss';
import starpodConfig from 'starpod.config';

import '../styles/global.css';

// Keep static left sidebar hidden by default.
const showStaticSidebar = false;

export interface Props {
  /**
   * If defined, this will override the default canonical URL.
   */
  canonicalURL?: URL;
  description?: string;
  feedQueryValue?: string;
  feedUrl?: string;
  imageUrl?: string;
  show?: Show;
  title: string;
}

const { feedQueryValue, feedUrl, imageUrl, show: providedShow, title } =
  Astro.props;
const show = providedShow ?? (await getShowInfo(feedUrl));
const currentFeedUrl = feedUrl ?? starpodConfig.rssFeed;
const socialImage = imageUrl ?? show.image;
const embedGateConfig = getEmbedGateConfig();
const searchDialogPersistKey = feedQueryValue
  ? `search-dialog:${encodeURIComponent(feedQueryValue)}`
  : 'search-dialog:default';

const canonicalURL =
  Astro.props.canonicalURL ?? new URL(Astro.url.pathname, Astro.site);
const description = Astro.props.description ?? starpodConfig.description;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <link rel="canonical" href={canonicalURL} />
    <meta content={canonicalURL} property="og:url" />
    <meta content="website" property="og:type" />
    {
      starpodConfig.platforms.appleIdNumber && (
        <meta
          name="apple-itunes-app"
          content={`app-id=${starpodConfig.platforms.appleIdNumber}`}
        />
      )
    }

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#5bbad5" />
    <meta name="msapplication-TileColor" content="#da532c" />
    <meta
      name="theme-color"
      content="#ffffff"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#1a1a1a"
      media="(prefers-color-scheme: dark)"
    />

    <!-- Title -->
    <title>{title}</title>
    <meta content={title} property="og:title" />
    <meta content={title} name="twitter:title" />

    <!-- Description -->
    <meta content={description} name="description" />
    <meta content={description} property="og:description" />
    <meta content={description} name="twitter:description" />

    <!-- Image -->
    {socialImage && <meta content={socialImage} property="og:image" />}
    <meta content="summary" name="twitter:card" />
    {socialImage && <meta content={socialImage} name="twitter:image:src" />}

    <meta property="og:site_name" content={show.title} />

    {socialImage && <link rel="preload" as="image" href={socialImage} />}

    <Font cssVariable="--astro-font-inter" preload />

    <Schema
      slot="head"
      item={{
        '@context': 'https://schema.org',
        '@type': 'PodcastSeries',
        name: show.title,
        about: starpodConfig.blurb,
        description: show.description,
        url: canonicalURL.toString(),
        webFeed: currentFeedUrl,
        author: {
          '@type': 'Organization',
          name: show.title,
          url: canonicalURL.origin
        },
        publisher: {
          '@type': 'Organization',
          name: show.title,
          url: canonicalURL.origin
        },
        image: show.image
      }}
    />

    <style is:inline>
      .iqpod-gate {
        position: fixed;
        inset: 0;
        z-index: 9999;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.72);
        backdrop-filter: blur(4px);
        padding: 1rem;
      }
      .iqpod-gate__card {
        width: min(420px, 100%);
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: #0f1426;
        color: #e8ecff;
        padding: 1rem;
      }
      .iqpod-gate__title {
        margin: 0 0 0.5rem;
        font-weight: 700;
        font-size: 1rem;
      }
      .iqpod-gate__hint {
        margin: 0 0 0.75rem;
        color: #b7c0e6;
        font-size: 0.9rem;
      }
      .iqpod-gate__row {
        display: flex;
        gap: 0.5rem;
      }
      .iqpod-gate__input {
        flex: 1;
        min-width: 0;
        border: 1px solid #2a3451;
        background: #0a1022;
        color: #e8ecff;
        border-radius: 8px;
        padding: 0.55rem 0.7rem;
      }
      .iqpod-gate__button {
        border: 0;
        border-radius: 8px;
        background: #5f7cd4;
        color: #fff;
        font-weight: 600;
        padding: 0.55rem 0.85rem;
        cursor: pointer;
      }
      .iqpod-gate__error {
        margin-top: 0.55rem;
        color: #ffb4b4;
        font-size: 0.82rem;
      }
    </style>

    <slot name="head" />
    <ClientRouter />
  </head>
  <body
    class="font-inter text-light-text-body dark:bg-dark-background dark:text-dark-text-body antialiased"
  >
    <div
      id="iqpod-gate"
      class="iqpod-gate"
      aria-live="polite"
      aria-modal="true"
      data-config={JSON.stringify(embedGateConfig)}
      hidden
      role="dialog"
    >
      <div class="iqpod-gate__card">
        <p class="iqpod-gate__title">Enter PIN to continue</p>
        <p class="iqpod-gate__hint">This view is restricted unless embedded on an allowed parent domain.</p>
        <div class="iqpod-gate__row">
          <input id="iqpod-gate-input" class="iqpod-gate__input" type="password" placeholder="PIN" />
          <button id="iqpod-gate-button" class="iqpod-gate__button" type="button">Unlock</button>
        </div>
        <div id="iqpod-gate-error" class="iqpod-gate__error" hidden>Invalid PIN</div>
      </div>
    </div>

    <script is:inline>
      (() => {
        const gate = document.getElementById('iqpod-gate');
        const pinInput = document.getElementById('iqpod-gate-input');
        const unlockButton = document.getElementById('iqpod-gate-button');
        const errorText = document.getElementById('iqpod-gate-error');

        if (!gate || !pinInput || !unlockButton || !errorText) return;

        let config;
        try {
          config = JSON.parse(gate.dataset.config || '{}');
        } catch {
          gate.hidden = true;
          return;
        }

        const matchesOriginPattern = (origin, pattern) => {
          const match = pattern
            .trim()
            .toLowerCase()
            .match(/^(https?):\/\/([^/:]+)(?::(\d+))?$/);

          if (!match) return false;

          try {
            const parsedOrigin = new URL(origin);
            const hostname = parsedOrigin.hostname.toLowerCase();
            const hostnamePattern = match[2];
            const expectedPort = match[3] || '';

            if (parsedOrigin.protocol.toLowerCase() !== `${match[1]}:`) {
              return false;
            }

            if (expectedPort && parsedOrigin.port !== expectedPort) {
              return false;
            }

            if (!expectedPort && parsedOrigin.port) {
              return false;
            }

            if (hostnamePattern.startsWith('*.')) {
              const suffix = hostnamePattern.slice(1);
              return hostname.endsWith(suffix) && hostname !== suffix.slice(1);
            }

            return hostname === hostnamePattern;
          } catch {
            return false;
          }
        };

        const hideGate = () => {
          gate.hidden = true;
          gate.style.display = 'none';
          errorText.hidden = true;
          pinInput.value = '';
        };

        const showGate = () => {
          gate.hidden = false;
          gate.style.display = 'flex';
        };

        const isUnlocked = () => {
          try {
            return window.localStorage.getItem(config.storageKey) === 'true';
          } catch {
            return false;
          }
        };

        const getAllowedParentOrigin = () => {
          const candidates = [];
          if (document.referrer) {
            try {
              candidates.push(new URL(document.referrer).origin);
            } catch {}
          }
          const ancestorOrigins = window.location.ancestorOrigins;
          if (ancestorOrigins && ancestorOrigins.length) {
            for (let i = 0; i < ancestorOrigins.length; i += 1) {
              candidates.push(ancestorOrigins[i]);
            }
          }
          for (const origin of candidates) {
            if (
              Array.isArray(config.allowedParents) &&
              config.allowedParents.some((pattern) =>
                matchesOriginPattern(origin, pattern)
              )
            ) {
              return origin;
            }
          }
          return null;
        };

        const inIframe = window.self !== window.top;
        const unlocked = isUnlocked();
        const allowedParent = inIframe ? getAllowedParentOrigin() : null;
        const requiresGate =
          Boolean(config.enabled) &&
          !unlocked &&
          (inIframe ? !allowedParent : !config.allowTopLevel);

        if (!requiresGate) {
          hideGate();
          return;
        }

        showGate();

        const handleUnlock = () => {
          if (pinInput.value.trim() !== config.pinCode) {
            errorText.hidden = false;
            return;
          }
          try {
            window.localStorage.setItem(config.storageKey, 'true');
          } catch {
            // Ignore storage failures and still allow the current session through.
          }
          hideGate();
        };

        unlockButton.addEventListener('click', handleUnlock);
        pinInput.addEventListener('keydown', (event) => {
          if (event.key === 'Enter') handleUnlock();
        });
      })();
    </script>

    <header
      class={showStaticSidebar
        ? 'custom-scrollbar lg:fixed lg:inset-y-0 lg:left-0 lg:flex lg:w-112 lg:items-start lg:overflow-y-auto xl:w-120'
        : 'hidden'}
      transition:persist="sidenav"
    >
      {showStaticSidebar && (
      <div class="relative z-10 mx-auto lg:min-h-full lg:flex-auto">
        <div
          class="bg-light-card dark:bg-dark-card m-2 rounded-lg pt-10 pb-4 lg:pt-16 lg:pb-12"
        >
          <ShowArtwork image={show.image} />

          <div class="px-4 sm:px-6 md:px-4 lg:px-16">
            <p
              class="text-light-text-heading mt-8 text-center text-2xl font-bold lg:text-left dark:text-white"
            >
              {show.title}
            </p>

            <p class="mt-2 text-center text-lg lg:text-left">
              {starpodConfig.blurb}
            </p>
          </div>

          <div class="px-4 sm:px-6 md:px-4 lg:px-16">
            <Platforms />
          </div>
          <div class="hidden lg:block">
            <Hosts />
          </div>
        </div>

        <div class="hidden lg:block">
          <InfoCard />
        </div>
      </div>
      )}
    </header>
    <main
      class={`bg-light-card dark:bg-dark-card mx-2 mb-2 rounded-lg lg:relative lg:min-h-screen ${showStaticSidebar ? 'lg:ml-112 xl:ml-120' : ''}`}
    >
      <div class="absolute top-4 right-4 z-30">
        <SearchButton client:load />
      </div>
      <div class="relative mt-2 pt-16">
        <div
          class="bg-gradient-light dark:bg-gradient-dark absolute top-0 right-0 left-0 z-0 h-80 w-full opacity-30"
        >
        </div>

        <Dots />

        <div class="max-w-4xl">
          <div
            class:list={[
              'dark:border-dark-border relative z-20 mb-12 border-b pb-6 lg:mb-16 lg:pb-10',
              Astro.url.pathname === '/' && 'hidden'
            ]}
          >
            <div class="ml-8 lg:ml-18">
              <Breadcrumbs title={title} />
            </div>
          </div>

          <slot />
        </div>
      </div>
    </main>
    {showStaticSidebar && (
    <footer class="block lg:hidden">
      <Hosts />
      <InfoCard />
    </footer>
    )}
    <div id="audio-player">
      <Player client:only="preact" transition:persist="player" />
    </div>
    <SearchDialog
      client:load
      feed={feedQueryValue}
      transition:persist={searchDialogPersistKey}
    />
    <SpeedInsights />
  </body>
</html>
